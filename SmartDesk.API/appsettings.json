{
  "ConnectionStrings": {
    "CosmosDb": "AccountEndpoint=https://YOUR_ACCOUNT.documents.azure.com:443/;AccountKey=YOUR_KEY;",
    "Redis": "YOUR_REDIS.redis.cache.windows.net:6380,password=YOUR_KEY,ssl=True,abortConnect=False"
  },

  "CosmosDb": {
    "DatabaseName": "SmartDeskDb",
    "TicketsContainer": "tickets",
    "UsersContainer": "users",
    "CommentsContainer": "comments"
  },

  "Jwt": {
    "Key": "YOUR-SECRET-KEY-MIN-32-CHARS-REPLACE-THIS-NOW",
    "Issuer": "https://smartdesk.yourdomain.com",
    "Audience": "smartdesk-api",
    "ExpiryMinutes": 60
  },

  "AzureServiceBus": {
    "ConnectionString": "Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY",
    "TopicName": "ticket-events",
    "SubscriptionName": "smartdesk-worker"
  },

  "AzureBlobStorage": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY",
    "ContainerName": "ticket-attachments"
  },

  "AzureKeyVault": {
    "VaultUri": "https://YOUR_VAULT.vault.azure.net/"
  },

  "Blazor": {
    "BaseUrl": "https://localhost:7001"
  },

  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_KEY",
    "Model": "gpt-4o-mini"
  },

  "ApiBaseUrl": "https://localhost:7000",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
